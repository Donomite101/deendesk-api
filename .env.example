# Required environment variables — add these in Vercel Dashboard → Settings → Environment Variables

# Brevo API Key (from brevo.com → SMTP & API → API Keys)
BREVO_API_KEY=your_brevo_api_key_here

# Sender email (must be verified in Brevo)
SENDER_EMAIL=noreply@deendesk.com

# Vercel KV — these are auto-populated when you connect a KV store in Vercel Dashboard
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
